# ─────────────────────────────────────────────
#  ÀGBÀR LIFE CARE — Environment Variables
#  Copy this file to .env.local and fill in values
#  NEVER commit .env.local to GitHub
# ─────────────────────────────────────────────

# Firebase (client-side) — get from Firebase Console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin (server-side) — get from Firebase Console → Project Settings → Service accounts
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Email (for confirmation emails — use Gmail with App Password, or Brevo free tier)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Àgbàr Life Care <noreply@agbarlifecare.com>

# Site URL (use http://localhost:3000 for dev, your Vercel URL for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
